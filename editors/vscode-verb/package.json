{
  "name": "vscode-verb",
  "displayName": "Verb",
  "description": "VSCode language support for Verb — LSP client, format-on-save, and tree-sitter syntax highlighting",
  "version": "0.0.1",
  "engines": {
    "vscode": "1.127.x"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:verb"
  ],
  "contributes": {
    "languages": [
      {
        "id": "verb",
        "extensions": [
          ".verb"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": [
      {
        "title": "Verb",
        "properties": {
          "verb.lspPath": {
            "type": "string",
            "default": "/Users/steffen/Desktop/Projekte/compiler/target/release/verb-lsp",
            "description": "Path to the verb-lsp binary"
          }
        }
      }
    ],
    "configurationDefaults": {
      "[verb]": {
        "editor.formatOnSave": true
      }
    }
  },
  "scripts": {
    "build": "tsc && node scripts/copy-wasm.js",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0",
    "web-tree-sitter": "^0.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.3.3"
  }
}
