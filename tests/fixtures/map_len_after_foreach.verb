%% Regression: `map_len(m)` must not collide with the `each`-over-iterable
%% lowering's own internal `map_len` declaration. Before the fix, an `each`
%% over an array or string (which emits a tag-dispatching `fe.map` block that
%% references `map_len`) followed by a user `map_len(m)` call produced a
%% duplicate LLVM symbol (`map_len.N`) -> JIT segfault / AOT link error.
%% See gen_std_io_call in src/codegen.rs.
import std map;

assign a list 1, 2, 3;
assign sum 0;
each n in a begin
  sum be sum add n;
end
print(sum);                                 %% 6

each ch in "ab" begin
  print(ch);
end

assign m map_new();
map_set(m, "x", 10);
map_set(m, "y", 20);
print(map_len(m));                          %% 2
