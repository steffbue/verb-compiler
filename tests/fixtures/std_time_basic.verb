import std time;

assign start monotonic_ms();
sleep_ms(20);
assign elapsed monotonic_ms() sub start;
print(elapsed atleast 20);

assign wall now_ms();
print(wall beats 0);

assign wall2 now_ms();
print(wall2 atleast wall);

print(difftime_ms(monotonic_ms(), start) atleast 20);

assign cpu1 clock_ms();
assign cpu2 clock_ms();
print(cpu1 atleast 0);
print(cpu2 atleast cpu1);
