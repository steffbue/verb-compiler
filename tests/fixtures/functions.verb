%% user-defined functions
fn add(a, b) begin
  return a plus b;
end
print(add(1, 2));

fn greet() begin
  print("hi");
end
greet();

fn noret(a) begin
  a be a plus 1;
end
print(noret(5));

fn fib(n) begin
  if n lo 2 begin return n; end
  return fib(n minus 1) plus fib(n minus 2);
end
print(fib(10));

assign f add;
print(f(3, 4));
print(add);
