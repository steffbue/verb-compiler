%% user-defined functions
make add2(a, b) begin
  return a add b;
end
print(add2(1, 2));

make greet() begin
  print("hi");
end
greet();

make noret(a) begin
  a be a add 1;
end
print(noret(5));

make fib(n) begin
  check n trails 2 begin return n; end
  return fib(n sub 1) add fib(n sub 2);
end
print(fib(10));

assign f add2;
print(f(3, 4));
print(add2);
